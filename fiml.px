//
// Fact Information Modelling Language. A CQL-like dialect
//

TOP	=
	?(BOM:bom)
	*statement
	-> bom, statement

BOM	=
	  '\uFEFF'

statement =
	(
		| concept
		| instance
		| query
		| generator
	) s '.'

//
// Concept rules
//

concept =
	'Each' ss name ss 'is' ss concept_definition ?(ss concept_property_list)
	
concept_definition =
	| 'a' ss 'concept'
	| concept_supertype ?(ss concept_type)
	| concept_type

concept_supertype =
	'a' ss 'kind' ss 'of' ss name

concept_type =
	| object_type_concept 
	| data_type_concept

object_type_concept =
	| 'identified' ss 'by' ss role_list 
	| 'where' ss fact_type

data_type_concept =
	'written' ss 'as' data_type

role_list =
	role +(sep role)

concept_property_list =
	'and' ss 'it' ss property +(sep property)

//
// Fact type rules
//

fact_type =
	reading +(s '/' s reading)

reading =
	*(predicator ss role ss) predicator ss ?(quantifier ss) role ?(ss predicator)

property =
	predicator ss ?(quantifier ss) role ?(ss predicator)
	
role =
	| name ss ?('(' s name s ')')
	| adjective ss name

name = 
	[\U] *[\L\d] *(ss [\U] *[\L\d])

predicator =
	!reserved_words +[\L] *(ss !reserved_words +[\L])

reserved_words =
	| quantifier
	| adjective

adjective =
	+[\L] '-' *(ss +[\L])

quantifier =
	| 'one'
	| 'at' ss 'most' ss 'one'
	| 'at' ss 'least' ss 'one'
	| 'many'

//
// Instance rules
//

instance = 
	name ':' ss '{' s keyed_datum_list s '}'
	
keyed_datum_list = 	
	keyed_datum *(sep keyed_datum)

keyed_datum =
	key ':' ss datum

key =
	[\L] *[\L\d] *([_] [\L] *[\L\d])

// //
// // Fact rules
// //

// fact = 
// 	*(predicator ss roled_datum ss) predicator ss roled_datum ?(ss predicator)

// roled_datum =
// 	?(name ss) datum

//
// Query rules
//

query =
	?with_generators 'for' ss 'each' ss path path_control s '=>' s selector

path =
	object_reference variable step_body *( sep step )

step =
	?( subject ss ) step_body
	
step_body = 
	predicator ss roled_expression ?(ss predicator)

object_reference =
	name ?selector

subject =
	| 'that'
	| 'who'
	| ?object_reference variable

variable =
	+[\U]

roled_expression =
	?(name ss) expression

path_control = 
	?(ss where_condition) ?(ss grouping)

where_condition =
	'where' ss boolean_expression

grouping =
	group_by ss ?group_condition

group_by =
	'group' ss 'by' ss name *(sep name)

group_condition =
	'having' ss boolean_expression

selector =
	| keyed_expression_list
	| fact_template

keyed_expression_list =
	'{' s keyed_expression *(sep keyed_expression) s '}'

keyed_expression =
	key ':' ss expression

fact_template =
	'(' s  *(predicator ss roled_expression ss) predicator ss roled_expression ?(ss predicator) s ')'

//
// Generator rules
//

with_generators = 
	'with' ss generator_list

generator_list =
	generator +(sep generator)

generator =
	name ':' ss '(' s query s ')'

//
// Data type rules
//

data_type =
	| value_type
	| 'a' ss 'struct' ss 'containing' ss element_list
	| 'an' ss 'array' ss 'of' ss data_type

element_list =
	'{' s role *( sep role) s '}'

value_type =
	builtin_value_type

builtin_value_type =
	| 'number'
	| 'string'
	| 'boolean'

//
// Expression rules
//

expression =
	| object_reference
	| numeric_expression
	| string_expression
	| boolean_expression

numeric_expression =
	numeric_term *(s addition_op s numeric_term)

addition_op =
	| '+' 
	| '-'

numeric_term =
	numeric_factor *(s multiplication_op s numeric_factor)

multiplication_op =
	| '*' 
	| '/'

numeric_factor =
	| number
	| ?[-+] accessor_expression
	| '(' s numeric_expression s ')'

accessor_expression =
	variable *(| '.' key | '[' s numeric_expression s ']')

string_expression =
	string_term *( s '+' s string_term)

string_term =
	| string_literal
	| accessor_expression
	| '(' s string_expression s ')'

boolean_expression =
	and_expression *( ss 'or' ss and_expression)

and_expression =
	not_expression *( ss 'and' ss not_expression)

not_expression =
	?'not' ss boolean_factor

boolean_factor =
	| boolean_literal
	| comparison
	| ?('not' ss) accessor_expression
	| '(' s boolean_expression s ')'

comparison =
	expression s comparison_operator s expression
	-> comparison_operator, expression

comparison_operator =
	| equal_to_op:op
	| not_equal_to_op:op
	| less_or_equal_op:op
	| less_than_op:op
	| greater_or_equal_op:op
	| greater_than_op:op
	-> op

equal_to_op =
	'=' ![>]

not_equal_to_op =
	| '<>'
	| '!='

less_than_op =
	'<' !'='

less_or_equal_op =
	'<='

greater_or_equal_op =
	'>='

greater_than_op =
	'>' ![=<]

// function_call =
// 	name '(' s ?(term *(s sep s term) ) ')' s
// 	-> name, term

//
// Datum rules
//

datum =
	| value:d
	| struct:d
	| array:d
	-> d

value = (
		| boolean_literal:v
		| string_literal:v
		| number:v
	)
	-> v

struct =
	'{' (|(s key:k ':' ss datum:v *(sep key:k ':' ss datum:v) s) | s) '}'
	-> k, v

array =
	'[' (|(s datum:e *(sep datum:e) s) |s) ']'
	-> e

boolean_literal =
	| 'true':v !\w
	| 'false':v !\w
	-> v

string_literal =
	'\'' *(string_char:c) '\''
 	-> c

string_char =
	| '\\' [befntr\\']
	| '\\' [0-7] [0-7] [0-7]
	| '\\' *[\r] [\n] *[\r]
	| '\\0'
	| '\\x' [0-9A-Fa-f] [0-9A-Fa-f]
	| '\\u' [0-9A-Fa-f] [0-9A-Fa-f] [0-9A-Fa-f] [0-9A-Fa-f]
	| !['\x01-\x07\x0A-\x1F] .	// Exclude control characters except tab. Cannot exclude NUL here

number = (
		| integer
		| real:number
		| fractional_real:number
		| hex_number:number
		| octal_number:number
	) !\w
	-> number

integer =
	?[-+] [1-9] *[0-9]

real =
	?[-+] [1-9] *[0-9] ?fraction ?exponent

fractional_real =
	?[-+] '0' fraction ?exponent

fraction =
	'.' +[0-9]

exponent =
	[Ee] ?[-+] +[0-9]

hex_number =
	'0x' +[0-9A-Fa-f]

octal_number =
	'0' *[0-7]

//
//  Whitespace rules
//

comment_to_eol =
  '//' *(!'\n' .)

comment_c_style =
  '/*' *(!'*/' . ) '*/'

ws =	*(			// Optional space
	  | +[ \t\n\r]		// one or more spaces
	  | comment_to_eol
	  | comment_c_style
	)

s = *ws		  // Optional space

ss = +ws	  // Mandatory space

sep =	',' s
