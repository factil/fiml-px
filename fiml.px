//
// Fact Information Modelling Language. A CQL-like dialect
//

TOP	=
	?(BOM:bom)
	*statement
	-> bom, statement

BOM	=
	  '\uFEFF'

statement =
	(
		| concept
		| instance
		| query
		| generator
	) s '.'

//
// Concept rules
//

concept =
	'Each' ss name ss 'is' ss (
		| 'a' ss 'concept'
		| (| concept_supertype | object_type_concept) ?(ss concept_property_list)
		| data_type_concept
	)

concept_supertype =
	'a' ss 'kind' ss 'of' ss name

object_type_concept =
	| 'identified' ss 'by' s role_list 
	| 'where' ss fact_type

data_type_concept =
	'written' ss 'as' data_type

role_list =
	'(' s role s +(sep role s) ')'

concept_property_list =
	'and' ss 'it' ss property +(s sep property)

//
// Fact type rules
//

fact_type =
	reading s +('/' s reading s)

reading =
	*(words ss role ss) words ss ?(quantifier ss) role ?(ss words)

property =
	words ss ?(quantifier ss) role ?(ss words)
	
role =
	name s ?('(' s name s ')')
	adjective ss name

name = 
	[\U] *[\L\d] *(ss [\U] *[\L\d])

words =
	!(| adjective | quantifier) +[\L] *(ss !(| adjective | quantifier) +[\L])

adjective =
	+[\L] '-' *(ss +[\L])

quantifier =
	| 'one'
	| 'at' ss 'most' ss 'one'
	| 'at' ss 'least' ss 'one'
	| 'many'

//
// Instance rules
//

instance = 
	name s ':' s '{' s keyed_datum_list s '}'
	
keyed_datum_list = 	
	keyed_datum *(s sep keyed_datum)

keyed_datum =
	key s ':' s datum

key =
	[\L] *[\L\d] *([_] [\L] *[\L\d])

// //
// // Fact rules
// //

// fact = 
// 	*(words ss roled_datum ss) words ss roled_datum ?(ss words)

// roled_datum =
// 	?(name ss) datum

//
// Query rules
//

query =
	?with_generators 'for' ss 'each' ss path path_control s '=>' s selector

path =
	roled_variable *(step)

roled_variable =
	?(name ss) variable

variable =
	+[\U]

step =
	words ss roled_expression ?(ss words)

roled_expression =
	?(name ss) expression

path_control = 
	?(ss where_condition) ?(ss grouping)

where_condition =
	'where' s boolean_expression

grouping =
	group_by ss ?group_condition

group_by =
	'group' ss 'by' ss name *(s sep name)

group_condition =
	'having' s boolean_expression

selector =
	'{' keyed_expression s *(sep keyed_expression s) '}'

keyed_expression =
	key s ':' s expression

//
// Generator rules
//

with_generators = 
	'with' ss generator_list

generator_list =
	generator +(s sep generator)

generator =
	name s ':' s '(' s query s ')'

//
// Data type rules
//

data_type =
	| value_type
	| 'a' ss 'struct' ss 'containing' s element_list
	| 'an' ss 'array' ss 'of' ss data_type

element_list =
	'{' s role s *( sep role s) '}'

value_type =
	builtin_value_type

builtin_value_type =
	| 'number'
	| 'string'
	| 'boolean'

//
// Expression rules
//

expression =
	| datum
	| numeric_expression
	| string_expression
	| boolean_expression

numeric_expression =
	numeric_term *((| '+' | '-') numeric_term)

numeric_term =
	numeric_factor *((| '*' | '/') numeric_factor)

numeric_factor =
	| number
	| reference
	| '(' numeric_expression ')'

reference =
	variable +('.' key)

string_expression =
	string_term *( '+' string_term)

string_term =
	| string_literal
	| reference
	| '(' string_expression ')'

boolean_expression =
	and_expression *( 'or' ss and_expression)

and_expression =
	not_expression *( 'and' ss not_expression)

not_expression =
	?'not' boolean_factor

boolean_factor =
	| boolean_literal
	| comparison
	| reference
	| '(' boolean_expression ')'

comparison =
	expression s comparison_operator expression
	-> comparison_operator, expression

comparison_operator =
	| equalTo:op
	| notEqualTo:op
	| lessOrEqual:op
	| lessThan:op
	| greaterOrEqual:op
	| greaterThan:op
	-> op

equalTo =
	'=' ![>]

notEqualTo =
	| '<>'
	| '!='

lessThan =
	'<' !'='

lessOrEqual =
	'<='

greaterOrEqual =
	'>='

greaterThan =
	'>' ![=<]

// function_call =
// 	name '(' s ?(term *(s sep s term) ) ')' s
// 	-> name, term

//
// Datum rules
//

datum =
	| value:d
	| struct:d
	| array:d
	-> d

value = (
		| boolean_literal:v
		| string_literal:v
		| number:v
	) s
	-> v

struct =
	'{' *(|(key:k ':' datum:v *(',' key:k ':' datum:v)) | s) '}'
	-> k, v

array =
	'[' (|(datum:e *(',' datum:e)) |s) ']'
	-> e

boolean_literal =
	| 'true':v !\w s
	| 'false':v !\w s
	-> v

string_literal =
	'\'' *(string_char:c) '\''
 	-> c

string_char =
	| '\\' [befntr\\']
	| '\\' [0-7] [0-7] [0-7]
	| '\\' *[\r] [\n] *[\r]
	| '\\0'
	| '\\x' [0-9A-Fa-f] [0-9A-Fa-f]
	| '\\u' [0-9A-Fa-f] [0-9A-Fa-f] [0-9A-Fa-f] [0-9A-Fa-f]
	| !['\x01-\x07\x0A-\x1F] .	// Exclude control characters except tab. Cannot exclude NUL here

number = (
		| natural_number
		| real:number
		| fractional_real:number
		| hex_number:number
		| octal_number:number
	) !\w
	-> number

real =
	?[-+] [1-9] *[0-9] ?fraction ?exponent

fractional_real =
	?[-+] '0' fraction ?exponent

fraction =
	'.' +[0-9]

exponent =
	[Ee] ?[-+] +[0-9]

natural_number =
	[1-9] *[0-9]

hex_number =
	'0x' +[0-9A-Fa-f]

octal_number =
	'0' *[0-7]

//
//  Whitespace rules
//

comment_to_eol =
  '//' *(!'\n' .)

comment_c_style =
  '/*' *(!'*/' . ) '*/'

ws =	*(			// Optional space
	  | +[ \t\n\r]		// one or more spaces
	  | comment_to_eol
	  | comment_c_style
	)

s = *ws		  // Optional space

ss = +ws	  // Mandatory space

sep =	sep
