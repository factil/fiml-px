//
// Fact Information Modelling Language. A CQL-like dialect
//

TOP	=
	?(BOM:bom)
	*(?s statement)
	-> bom, statement

BOM	=
	  '\uFEFF'

statement =
	(
		| concept
		| instance
		| query
		| generator
	) s '.' ?white_to_eol (| '\n' | EOF)

EOF =					// End of file is where nothing follows
	!.

//
// Concept rules
//

concept =
	'Each' ss name ss 'is' ss concept_declaration ?(ss concept_property_list)
	
concept_declaration =
	| 'a' ss 'concept'
	| concept_supertype ?(ss concept_type)
	| concept_type

concept_supertype =
	'a' ss 'kind' ss 'of' ss name

concept_type =
	| object_type_declaration 
	| data_type_declaration

object_type_declaration =
	| entity_type_declaration
	| fact_type_declaration

entity_type_declaration =
	'identified' ss 'by' ss identifier_list

fact_type_declaration = 
	'where' ss fact_type

data_type_declaration =
	'written' ss 'as' ss data_type

identifier_list =
	identifier *(sep identifier)

identifier =
	item

concept_property_list =
	'and' ss pronoun ss property *(sep property)

pronoun =
	| 'it'
	| 'they'

//
// Fact type rules
//

fact_type =
	reading +(s '/' s reading)

reading =
	| ?(preamble ss) +(role ss predicator ss) quantified_role ?(ss postamble)
	| role ss predicator

property =
	property_reading ?(s '/' s role ss property_reading)

property_reading =
	predicator ss quantified_role ?(ss postamble)

quantified_role =
	?(quantifier ss) role

role =
	item

item =
	| name ?(ss '(' s name s ')')
	| adjective ss name

name = 
  // 	[\U] +[\L\d] *(ss [\U] +[\L\d])
	[\U] +[\L\d] *(&(ss [\U] +[\L\d]) ss [\U] +[\L\d])

preamble =
	predicate_words

predicator =
	predicate_words
	
postamble =
	predicate_words
	
predicate_words =
	!reserved_words +[\L] *(ss !reserved_words +[\L])

reserved_words =
	| quantifier
	| adjective

adjective =
	+[\L] '-' *(ss +[\L])

quantifier =
	| 'one'
	| 'at' ss 'most' ss 'one'
	| 'at' ss 'least' ss 'one'
	| 'many'
	| 'where'
	| 'group' ss 'by'

//
// Instance rules
//

instance = 
	name ':' ss instance_body

instance_body =
	| datum
	| '(' s instance_literal s ')'

instance_literal =
	name object_reference ?(property_literal *(sep property_literal))

property_literal =
	predicator ss role_literal ?(ss postamble)

//
// Fact rules
//

fact = 
	| role_literal ss predicator
 	| ?(preamble ss) +(role_literal ss predicator ss) role_literal ?(ss postamble)

role_literal =
 	| ?(name ss) datum
	| name ss object_reference

object_reference =
	| keyed_datum_list
	| '(' s fact s ')'

keyed_datum_list = 	
	'{' s keyed_datum *(sep keyed_datum) s '}'

keyed_datum =
	key ':' ss datum

key =
	[\L] *[\L\d] *([_] [\L] *[\L\d])

//
// Query rules
//

query =
	?(with_generators ss) [Ff] 'or' ss 'each' ss path path_control s '=>' s selector

path =
	object_template ss variable ss step_body *( sep step )

step =
	?( subject ss ) step_body
	
step_body = 
	predicator ss roled_expression ?(ss postamble)

object_template =
	name ?(object_selector)

object_selector =
	| keyed_expression_list
	| '(' s fact_template s ')'	

subject =
	| relative_pronoun
	| ?(object_template ss) variable

relative_pronoun =
	| 'that'
	| 'who'

variable =
	+[\U]

roled_expression =
	| object_template ss variable
	| ?(name ss) expression

path_control = 
	?(ss where_condition) ?(ss grouping)

where_condition =
	'where' ss boolean_expression

grouping =
	group_by ss ?group_condition

group_by =
	'group' ss 'by' ss name *(sep name)

group_condition =
	'having' ss boolean_expression

selector =
	| keyed_expression_list
	| '(' s instance_template s ')'

keyed_expression_list =
	'{' s keyed_expression *(sep keyed_expression) s '}'

keyed_expression =
	key ':' ss expression

instance_template =
	object_template ?(ss property_template *(sep property_template))

property_template =
	predicator ss roled_expression ?(ss predicator)

fact_template =
	?( preamble ss ) +(roled_expression ss predicator ss) roled_expression ?(ss postamble)

// fact_template =
//	?( preamble ss ) +fact_template_loop roled_expression ?(ss postamble)
	
fact_template_loop = 
	&(fact_template_step ss roled_expression) fact_template_step ss

fact_template_step =	
	roled_expression ss predicator

//
// Generator rules
//

generator =
	name ':' ss '(' s query s ')'

with_generators = 
	[Ww] 'ith' ss generator_list

generator_list =
	generator +(sep generator)

//
// Data type rules
//

data_type =
	| value_type
	| 'a' ss 'struct' ss 'containing' ss element_list
	| 'an' ss 'array' ss 'of' ss data_type

element_list =
	'{' s element *( sep element) s '}'

element =
	item

value_type =
	builtin_value_type

builtin_value_type =
	| 'Number'
	| 'String'
	| 'Boolean'
	| 'Date Time'

//
// Expression rules
//

expression =
	| accessor_expression
	| numeric_expression
	| string_expression
	| boolean_expression

accessor_expression =
	variable *(| '.' key | '[' s numeric_expression s ']')

numeric_expression =
	numeric_term *(s addition_operator s numeric_term)

addition_operator =
	| '+' 
	| '-'

numeric_term =
	numeric_factor *(s multiplication_operator s numeric_factor)

multiplication_operator =
	| '*' 
	| '/'

numeric_factor =
	| number
	| ?'-' accessor_expression
	| '(' s numeric_expression s ')'

string_expression =
	string_term *( s '+' s string_term)

string_term =
	| string_literal
	| accessor_expression
	| '(' s string_expression s ')'

boolean_expression =
	and_expression *( ss 'or' ss and_expression)

and_expression =
	not_expression *( ss 'and' ss not_expression)

not_expression =
	?'not' ss boolean_factor

boolean_factor =
	| boolean_literal
	| comparison
	| accessor_expression
	| 'exists' ss '(' s query s ')'
	| '(' s boolean_expression s ')'

comparison =
	expression s comparison_operator s expression
	-> comparison_operator, expression

comparison_operator =
	| equal_to_operator:op
	| not_equal_to_operator:op
	| less_or_equal_operator:op
	| less_than_operator:op
	| greater_or_equal_operator:op
	| greater_than_operator:op
	-> op

equal_to_operator =
	'=' ![>]

not_equal_to_operator =
	| '<>'
	| '!='

less_than_operator =
	'<' !'='

less_or_equal_operator =
	'<='

greater_or_equal_operator =
	'>='

greater_than_operator =
	'>' ![=<]

// function_call =
// 	name '(' s ?(term *(s sep s term) ) ')' s
// 	-> name, term

//
// Datum rules
//

datum =
	| value:d
	| struct:d
	| array:d
	-> d

value =
	| boolean_literal:v
	| string_literal:v
	| number:v
	-> v

struct =
	'{' (|(s key:k ':' ss datum:v *(sep key:k ':' ss datum:v) s) | s) '}'
	-> k, v

array =
	'[' (|(s datum:e *(sep datum:e) s) |s) ']'
	-> e

boolean_literal =
	| 'true':v !\w
	| 'false':v !\w
	-> v

string_literal =
	'\'' *(string_char:c) '\''
 	-> c

string_char =
	| '\\' [befntr\\']
	| '\\' [0-7] [0-7] [0-7]
	| '\\' *[\r] [\n] *[\r]
	| '\\0'
	| '\\x' [0-9A-Fa-f] [0-9A-Fa-f]
	| '\\u' [0-9A-Fa-f] [0-9A-Fa-f] [0-9A-Fa-f] [0-9A-Fa-f]
	| !['\x01-\x07\x0A-\x1F] .	// Exclude control characters except tab. Cannot exclude NUL here

number = (
		| integer:number
		| real:number
		| fractional_real:number
		| hex_number:number
		| octal_number:number
	) !\w
	-> number

integer =
	?[-+] [1-9] *[0-9]

real =
	?[-+] [1-9] *[0-9] ?fraction ?exponent

fractional_real =
	?[-+] '0' fraction ?exponent

fraction =
	'.' +[0-9]

exponent =
	[Ee] ?[-+] +[0-9]

hex_number =
	'0x' +[0-9A-Fa-f]

octal_number =
	'0' *[0-7]

//
//  Separator and whitespace rules
//

sep =	',' s

comment_to_eol =
  '//' *(!'\n' .)

comment_c_style =
  '/*' *(!'*/' . ) '*/'

whitespace =
	| +[ \t\n\r]		    // one or more spaces
	| comment_to_eol
	| comment_c_style

white_to_eol =			  // whitespace except for \n
	| +[ \t\r]		      // one or more inline spaces
	| comment_to_eol
	| comment_c_style white_to_eol
	
s = *whitespace		  // Optional space

ss = +whitespace	  // Mandatory space
